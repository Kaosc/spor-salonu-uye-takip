{
  "name": "gymtrack",
  "version": "1.0.0",
  "main": "index.tsx",
  "scripts": {
    "start": "expo start --dev-client --scheme gymtrack",
    "android": "npx expo run:android",
    "ios": "npx expo run:ios",
    "web": "npx expo start --web",
    "doc": "npx expo-doctor",
    "docfix": "npx expo install --check",
    "bundle": "yarn update && cd android && ./gradlew bundleRelease && cd .. && yarn openbundledir",
    "bundledebug": "cd android && ./gradlew bundleDebug && cd ..",
    "cleanbundle": "cd android && ./gradlew clean && ./gradlew bundleRelease && cd ..",
    "clean": "cd android && ./gradlew clean && cd ..",
    "abb": "npx react-native build-android --mode=release -- --reset-cache",
    "runabb": "cd android && ./gradlew bundleRelease && npx react-native run-android --mode=release",
    "runondevice": "npx react-native run-android --mode=release",
    "update": "node version.updater.js",
    "openbundledir": "explorer D:\\Dev\\driverbook\\android\\app\\build\\outputs\\bundle\\release",
    "openbundledirmac": "open android/app/build/outputs/bundle/release",
    "pod": "cd ios && pod install && cd .."
  },
